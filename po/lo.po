#. Translators: This is the menu entry to select
#. when one wants to input only Simplified Chinese.
#. Translators: This is the setting to use only
#. simplified Chinese
#: engine/table.py:683 setup/main.py:393
msgid "Simplified Chinese"
msgstr "ພາສາຈີນຕົວຫຍໍ້"

#: engine/table.py:685
msgid "Switch to “Simplified Chinese only”."
msgstr "ສະຫຼັບໄປໃຊ້ “ພາສາຈີນຕົວຫຍໍ້ເທົ່ານັ້ນ”."

#. Translators: This is the menu entry to select
#. when one wants to input only Traditonal Chinese
#. Translators: This is the setting to use only
#. traditional Chinese
#: engine/table.py:692 setup/main.py:397
msgid "Traditional Chinese"
msgstr "ພາສາຈີນຕົວເຕັມ"

#: engine/table.py:694
msgid "Switch to “Traditional Chinese only”."
msgstr "ສະຫຼັບໄປໃຊ້ “ພາສາຈີນຕົວເຕັມເທົ່ານັ້ນ”."

#. Translators: This is the menu entry to select when
#. one wants to input both Simplified and Traditional
#. Chinese but wants the Simplified Chinese to be
#. preferred, i.e. shown higher up in the candidate
#. lists.
#: engine/table.py:704
msgid "Simplified Chinese first"
msgstr "ພາສາຈີນຕົວຫຍໍ້ກ່ອນ"

#: engine/table.py:706
msgid "Switch to “Simplified Chinese before traditional”."
msgstr "ສະຫຼັບໄປໃຊ້ “ພາສາຈີນຕົວຫຍໍ້ກ່ອນຕົວເຕັມ”."

#. Translators: This is the menu entry to select when
#. one wants to input both Simplified and Traditional
#. Chinese but wants the Traditional Chinese to be
#. preferred, i.e. shown higher up in the candidate
#. lists.
#: engine/table.py:716
msgid "Traditional Chinese first"
msgstr "ພາສາຈີນຕົວເຕັມກ່ອນ"

#: engine/table.py:718
msgid "Switch to “Traditional Chinese before simplified”."
msgstr "ສະຫຼັບໄປໃຊ້ “ພາສາຈີນຕົວເຕັມກ່ອນຕົວຫຍໍ້”."

#. Translators: This is the menu entry to select when
#. one wants to input both Simplified and Traditional
#. Chinese and has no particular preference whether
#. simplified or traditional characters should be higher
#. up in the candidate lists.
#. Translators: This is the setting to use both
#. simplified and traditional Chinese in no
#. particular order
#: engine/table.py:728 setup/main.py:412
msgid "All Chinese characters"
msgstr "ຕົວອັກສອນຈີນທັງໝົດ"

#: engine/table.py:729
msgid "Switch to “All Chinese characters”."
msgstr "ສະຫຼັບໄປໃຊ້ “ຕົວອັກສອນຈີນທັງໝົດ”."

#: engine/table.py:733 setup/main.py:1196
msgid "Chinese mode"
msgstr "ໂໝດພາສາຈີນ"

#: engine/table.py:734
msgid "Switch Chinese mode"
msgstr "ສະຫຼັບໂໝດພາສາຈີນ"

#: engine/table.py:745
msgid "English"
msgstr "ພາສາອັງກິດ"

#: engine/table.py:746
msgid "Switch to English input"
msgstr "ສະຫຼັບໄປໃຊ້ການປ້ອນຂໍ້ມູນພາສາອັງກິດ"

#: engine/table.py:753
msgid "Chinese"
msgstr "ພາສາຈີນ"

#: engine/table.py:754
msgid "Switch to Chinese input"
msgstr "ສະຫຼັບໄປໃຊ້ການປ້ອນຂໍ້ມູນພາສາຈີນ"

#: engine/table.py:762 engine/table.py:910 setup/main.py:963
msgid "Direct"
msgstr "ໂດຍກົງ"

#: engine/table.py:763
msgid "Switch to direct input"
msgstr "ສະຫຼັບໄປໃຊ້ການປ້ອນຂໍ້ມູນໂດຍກົງ"

#: engine/table.py:768 engine/table.py:832
msgid "Table"
msgstr "ຕາຕະລາງ"

#: engine/table.py:769
msgid "Switch to table input"
msgstr "ສະຫຼັບໄປໃຊ້ການປ້ອນຂໍ້ມູນແບບຕາຕະລາງ"

#: engine/table.py:777
msgid "Input mode"
msgstr "ໂໝດການປ້ອນຂໍ້ມູນ"

#: engine/table.py:778
msgid "Switch Input mode"
msgstr "ສະຫຼັບໂໝດການປ້ອນຂໍ້ມູນ"

#. Translators: This is the mode to use half width letters
#. while in “Table input” mode.
#. Translators: This is the mode to use half width punctuation
#. while in “Table input” mode.
#. Translators: This is the mode to use half width letters
#. while in “Direct input” mode.
#. Translators: This is the mode to use half width punctuation
#. while in “Direct input” mode.
#: engine/table.py:788 engine/table.py:810 setup/main.py:449 setup/main.py:493
#: setup/main.py:538 setup/main.py:583
msgid "Half"
msgstr "ເຄິ່ງຄວາມກວ້າງ"

#: engine/table.py:789
msgid "Switch to halfwidth letters"
msgstr "ສະຫຼັບໄປໃຊ້ຕົວອັກສອນເຄິ່ງຄວາມກວ້າງ"

#. Translators: This is the mode to use full width letters
#. while in “Table input” mode.
#. Translators: This is the mode to use full width punctuation
#. while in “Table input” mode.
#. Translators: This is the mode to use full width letters
#. while in “Direct input” mode.
#. Translators: This is the mode to use full width punctuation
#. while in “Direct input” mode.
#: engine/table.py:794 engine/table.py:816 setup/main.py:453 setup/main.py:497
#: setup/main.py:542 setup/main.py:587
msgid "Full"
msgstr "ເຕັມຄວາມກວ້າງ"

#: engine/table.py:795
msgid "Switch to fullwidth letters"
msgstr "ສະຫຼັບໄປໃຊ້ຕົວອັກສອນເຕັມຄວາມກວ້າງ"

#: engine/table.py:799 setup/main.py:1197
msgid "Letter width"
msgstr "ຄວາມກວ້າງຂອງຕົວອັກສອນ"

#: engine/table.py:800
msgid "Switch letter width"
msgstr "ສະຫຼັບຄວາມກວ້າງຂອງຕົວອັກສອນ"

#: engine/table.py:811
msgid "Switch to halfwidth punctuation"
msgstr "ສະຫຼັບໄປໃຊ້ເຄື່ອງໝາຍວັກຕອນເຄິ່ງຄວາມກວ້າງ"

#: engine/table.py:817
msgid "Switch to fullwidth punctuation"
msgstr "ສະຫຼັບໄປໃຊ້ເຄື່ອງໝາຍວັກຕອນເຕັມຄວາມກວ້າງ"

#: engine/table.py:821 setup/main.py:1198
msgid "Punctuation width"
msgstr "ຄວາມກວ້າງຂອງເຄື່ອງໝາຍວັກຕອນ"

#: engine/table.py:822
msgid "Switch punctuation width"
msgstr "ສະຫຼັບຄວາມກວ້າງຂອງເຄື່ອງໝາຍວັກຕອນ"

#: engine/table.py:833
msgid "Switch to table mode"
msgstr "ສະຫຼັບໄປໃຊ້ໂໝດຕາຕະລາງ"

#: engine/table.py:838
msgid "Pinyin"
msgstr "ພິນອິນ (Pinyin)"

#: engine/table.py:839
msgid "Switch to pinyin mode"
msgstr "ສະຫຼັບໄປໃຊ້ໂໝດພິນອິນ"

#: engine/table.py:843 setup/main.py:1199
msgid "Pinyin mode"
msgstr "ໂໝດພິນອິນ"

#: engine/table.py:844
msgid "Switch pinyin mode"
msgstr "ສະຫຼັບໂໝດພິນອິນ"

#: engine/table.py:854
msgid "Suggestion disabled"
msgstr "ປິດການແນະນຳຄຳສັບ"

#: engine/table.py:855 engine/table.py:861
msgid "Switch to suggestion mode"
msgstr "ສະຫຼັບໄປໃຊ້ໂໝດການແນະນຳ"

#: engine/table.py:860
msgid "Suggestion enabled"
msgstr "ເປີດການແນະນຳຄຳສັບ"

#: engine/table.py:865 setup/main.py:1200
msgid "Suggestion mode"
msgstr "ໂໝດການແນະນຳ"

#: engine/table.py:866
msgid "Switch suggestion mode"
msgstr "ສະຫຼັບໂໝດການແນະນຳ"

#: engine/table.py:876
msgid "Multiple character match"
msgstr "ຈັບຄູ່ຫຼາຍຕົວອັກສອນ"

#: engine/table.py:878
msgid "Switch to matching multiple characters at once"
msgstr "ສະຫຼັບໄປໃຊ້ການຈັບຄູ່ຫຼາຍຕົວອັກສອນພ້ອມກັນ"

#: engine/table.py:883
msgid "Single character match"
msgstr "ຈັບຄູ່ຕົວອັກສອນດຽວ"

#: engine/table.py:885
msgid "Switch to matching only single characters"
msgstr "ສະຫຼັບໄປໃຊ້ການຈັບຄູ່ສະເພາະຕົວອັກສອນດຽວ"

#: engine/table.py:889 setup/main.py:1201
msgid "Onechar mode"
msgstr "ໂໝດຕົວອັກສອນດຽວ"

#: engine/table.py:890
msgid "Switch onechar mode"
msgstr "ສະຫຼັບໂໝດຕົວອັກສອນດຽວ"

#: engine/table.py:900 setup/main.py:961
msgid "Normal"
msgstr "ປົກກະຕິ"

#: engine/table.py:902
msgid ""
"Switch to normal commit mode (automatic commits go into the preedit instead "
"of into the application. This enables automatic definitions of new shortcuts)"
msgstr ""
"ສະຫຼັບໄປໃຊ້ໂໝດການສົ່ງຄຳສັບແບບປົກກະຕິ (ການສົ່ງຄຳສັບອັດຕະໂນມັດຈະໄປຢູ່ທີ່ສ່ວນແກ້ໄຂກ່ອນ ແທນທີ່ຈະສົ່ງເຂົ້າໄປ"
"ໃນແອັບພລິເຄຊັນໂດຍກົງ. ສິ່ງນີ້ຊ່ວຍໃຫ້ສາມາດກຳນົດປຸ່ມລັດໃໝ່ໄດ້ໂດຍອັດຕະໂນມັດ)"

#: engine/table.py:912
msgid ""
"Switch to direct commit mode (automatic commits go directly into the "
"application)"
msgstr ""
"ສະຫຼັບໄປໃຊ້ໂໝດການສົ່ງຄຳສັບໂດຍກົງ (ການສົ່ງຄຳສັບອັດຕະໂນມັດຈະສົ່ງເຂົ້າໄປໃນແອັບພລິເຄຊັນໂດຍກົງ)"

#: engine/table.py:917 setup/main.py:1202
msgid "Autocommit mode"
msgstr "ໂໝດການສົ່ງຄຳສັບອັດຕະໂນມັດ"

#: engine/table.py:918
msgid "Switch autocommit mode"
msgstr "ສະຫຼັບໂໝດການສົ່ງຄຳສັບອັດຕະໂນມັດ"

